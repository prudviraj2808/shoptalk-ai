# Copy this to .env and fill in values. Never commit .env to git.

# Database
DB_USER=user
DB_PASSWORD=changeme_use_strong_password
DATABASE_URL=postgresql+asyncpg://user:changeme_use_strong_password@db:5432/shoptalk

# App
ENV=production
ALLOWED_ORIGINS=https://yourfrontend.com
AGENT_DIR=./agents
PORT=8000

# Model & Data
LORA_ADAPTER_PATH=./models/shoptalk-lora-adapter
DATA_DIR=./data
ABO_TAR_FILE=abo-images-small.tar
ABO_METADATA_FILE=listings.csv

# Model config
MODEL_NAME=MobileCLIP2-S2
PRETRAINED=dfndr2b
DEVICE=cuda
BATCH_SIZE=16
LEARNING_RATE=5e-5
EPOCHS=3

# AWS
ENDPOINT_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# Google
GOOGLE_API_KEY=
